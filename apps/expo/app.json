{
  "expo": {
    "owner": "getyourfit",
    "name": "Get Your Fit",
    "slug": "get-your-fit",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "gyf",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Get Your Fit to choose your profile picture."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cdc5a042-8bfb-4618-a161-c0f364851cf8"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
