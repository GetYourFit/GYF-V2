# GYF web — local env. Copy to .env.local and fill in.
#
# PRODUCTION (Cloudflare): `bun run cf:deploy` (opennextjs build) INLINES these
# NEXT_PUBLIC_* at build time, so create `app/.env.production.local` with prod values
# before deploying — otherwise the worker ships pointing at localhost:8000. Required
# there: NEXT_PUBLIC_API_URL = the Render API URL (e.g. https://gyf-api.onrender.com)
# plus the same Supabase URL + anon key as below. (.env.production.local is gitignored.)

# The FastAPI core (see Makefile `make dev-api` / `make stack`).
NEXT_PUBLIC_API_URL=https://gyf-api.onrender.com

# Supabase Auth (project → Settings → API). The anon key is browser-safe.
# The API must verify the same project's JWTs: prefer GYF_SUPABASE_URL (JWKS/ES256)
# on the FastAPI side, with SUPABASE_JWT_SECRET as the legacy HS256 fallback, so its
# auth_is_open mode is off outside local.
NEXT_PUBLIC_SUPABASE_URL=https://tabjvaatrikogutkrjom.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRhYmp2YWF0cmlrb2d1dGtyam9tIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3NDY3MjYsImV4cCI6MjA5NzMyMjcyNn0.ElJNK_w5DkQ2XbRRdU-VDp4ZDlsCtuDOgZkgxJnEdV4
