# GYF web — local env. Copy to .env.local and fill in.

# The FastAPI core (see Makefile `make dev-api` / `make stack`).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (project → Settings → API). The anon key is browser-safe.
# The API must verify the same project's JWTs: set SUPABASE_JWT_SECRET +
# JWT_AUDIENCE on the FastAPI side so its auth_is_open mode is off outside local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
