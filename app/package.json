{
  "name": "@gyf/web",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf:clean": "rm -rf .next .open-next node_modules/.cache",
    "cf:build": "bun run cf:clean && opennextjs-cloudflare build",
    "cf:preview": "bun run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "bun run cf:build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@gyf/types": "workspace:*",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@vercel/otel": "^2.1.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.8",
    "wrangler": "^4.103.0"
  }
}
