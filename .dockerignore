# Keep build contexts tiny and clean. Three images build from the repo root (ml bake-off,
# services/api, app/web); each COPYs only what it needs. Exclude everything heavy, host-
# specific, or regenerable so nothing host-built (esp. node_modules/.venv across OS/arch)
# leaks into an image.
.git
.github
services/api/.env

# Host-built dependency trees — always reinstalled inside the image.
.venv
**/.venv
node_modules
**/node_modules

# Caches and build output.
.turbo
**/.turbo
.ruff_cache
**/.ruff_cache
.pytest_cache
**/.pytest_cache
**/__pycache__
**/*.pyc
app/.next
**/*.tsbuildinfo

# Model-weight cache lives in a Docker named volume, never in an image/context.
.hf-cache

# Large catalog images are bind-mounted read-only at run time, not baked in.
data
ml/data
ml/*.jpg
ml/*.jpeg
ml/*.png

# Provisioning tooling and local docs not needed by any image build.
.tools
docs
