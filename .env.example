# Copy to .env and fill. Never commit real secrets.

# Web / BFF
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Core API
GYF_ENV=local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gyf
REDIS_URL=redis://localhost:6379/0

# Object storage (S3-compatible)
S3_ENDPOINT=
S3_BUCKET=gyf-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Events (Kafka/Redpanda)
EVENT_BROKER_URL=localhost:9092

# Auth (OIDC) — fill in P0/P1
AUTH_ISSUER=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
