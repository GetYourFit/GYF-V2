# Copy to .env and fill. Never commit real secrets.

# Web / BFF
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Core API (Settings reads the GYF_ prefix — see services/api/app/config.py)
GYF_ENV=local
GYF_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gyf
GYF_REDIS_URL=redis://localhost:6379/0

# Auth (Supabase JWT). Set GYF_SUPABASE_JWT_SECRET in staging/prod to enforce
# auth on protected routes. Leave empty in local (env=local) for the dev bypass.
GYF_SUPABASE_JWT_SECRET=
# GYF_AUTH_DISABLED=true  # force the dev principal (local only; never in prod)

# Object storage (S3-compatible)
S3_ENDPOINT=
S3_BUCKET=gyf-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Events (Kafka/Redpanda)
EVENT_BROKER_URL=localhost:9092

# Auth (OIDC) — fill in P0/P1
AUTH_ISSUER=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

# Event sink: "local" (JSONL), "kafka", or "postgres" (interactions table)
GYF_EVENT_SINK=local
GYF_EVENT_TOPIC=gyf.interactions

# --- Observability (P0-E). All optional; unset = no-op, no external service needed. ---
# Core API (GYF_ prefix). Metrics are always exposed at /metrics (Prometheus scrape).
# GYF_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # enables OTLP tracing
# GYF_SENTRY_DSN=                                          # enables Sentry error reporting
GYF_SERVICE_NAME=gyf-api
GYF_TRACE_SAMPLE_RATE=1.0
# Web (Next.js instrumentation reads standard OTEL_* vars).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=gyf-web
